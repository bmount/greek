          "continuity": "Ancient θέλω / ἐθέλω 'I wish, want'. The root of 'monothelitism' (one-will).",
          "forms": [ "θέλω — I want", "θέλεις — you want", "θέλει — he/she/it wants" ],
          "phrases": [
            { "gr": "Θέλω νερό.", "en": "I want water.", "es": "Quiero agua." },
            { "gr": "Τι θέλεις;", "en": "What do you want?", "es": "¿Qué quieres?" }
