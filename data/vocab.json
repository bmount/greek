  "lessons": [
    {
      "id": "L01",
      "title": "Being, wanting, seeing — and five things to talk about",
      "blurb": "Fifteen of the highest-frequency words in Greek. Together they already make real sentences: 'The person is here.' 'Where is the water?' 'I want the book.' Almost every one is historically continuous — you are also learning Koine.",
      "words": [
        { "id": "eimai", "gr": "είμαι", "en": "to be (I am)", "es": "ser / estar (soy, estoy)",
          "pos": "verb", "cat": "function", "rank": 1, "koine": "εἰμί",
          "continuity": "Directly from ancient εἰμί. The 3rd-person είναι 'is' descends from ἐστί; the imperfect ἦν opens John 1:1.",
          "forms": [ "είμαι — I am", "είσαι — you are", "είναι — he/she/it is" ],
          "phrases": [
            { "gr": "Είμαι εδώ.", "en": "I am here.", "es": "Estoy aquí." },
            { "gr": "Πού είσαι;", "en": "Where are you?", "es": "¿Dónde estás?" }
          ] },
        { "id": "echo", "gr": "έχω", "en": "to have (I have)", "es": "tener (tengo)",
          "pos": "verb", "cat": "function", "rank": 8, "koine": "ἔχω",
          "continuity": "Same verb as ancient ἔχω 'I have, hold'. Gives English -ech in 'cachexia', and 'hectic' (ἑκτικός).",
          "forms": [ "έχω — I have", "έχεις — you have", "έχει — he/she/it has" ],
          "phrases": [
            { "gr": "Έχω νερό.", "en": "I have water.", "es": "Tengo agua." },
            { "gr": "Έχεις ένα βιβλίο;", "en": "Do you have a book?", "es": "¿Tienes un libro?" }
          ] },
