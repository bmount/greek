    "tiers": [
      { "id": "function", "label": "Core function words", "target": 400,
        "note": "and, but, if, because · this/that/here/there · be/have/go/come · who/what/when/where · prepositions, pronouns, common verbs. A huge proportion of ordinary speech." },
      { "id": "nouns", "label": "High-frequency concrete nouns", "target": 400,
        "note": "house, water, child, hand, bread, sea, mountain, road, money, friend …" },
      { "id": "abstract", "label": "Adjectives & abstract words", "target": 200,
        "note": "good, difficult, possible, beautiful, true, important, early, already …" }
    ],
    "method": "Morphology in context (never bare dictionary forms), deliberate recycling over breadth, Modern pronunciation with vocabulary chosen for Koine/Classical continuity."
