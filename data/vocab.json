            { "gr": "Το βιβλίο είναι εδώ.", "en": "The book is here.", "es": "El libro está aquí." }
          ] },
        { "id": "filos", "gr": "φίλος", "article": "ο", "en": "friend", "es": "amigo",
          "pos": "noun", "gender": "m", "cat": "noun", "rank": 75, "koine": "φίλος",
