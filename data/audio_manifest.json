    "john-1-1": {
      "voice": "charon",
      "gender": "m",
      "kind": "verse",
      "text": "Ἐν ἀρχῇ ἦν ὁ λόγος, καὶ ὁ λόγος ἦν πρὸς τὸν θεόν, καὶ θεὸς ἦν ὁ λόγος.",
      "ref": "1:1",
      "source": "john"
    },
    "john-1-2": {
      "voice": "charon",
      "gender": "m",
      "kind": "verse",
      "text": "οὗτος ἦν ἐν ἀρχῇ πρὸς τὸν θεόν.",
      "ref": "1:2",
      "source": "john"
    },
    "john-1-3": {
      "voice": "charon",
      "gender": "m",
      "kind": "verse",
      "text": "πάντα δι᾽ αὐτοῦ ἐγένετο, καὶ χωρὶς αὐτοῦ ἐγένετο οὐδὲ ἓν ὃ γέγονεν.",
      "ref": "1:3",
      "source": "john"
    },
    "john-1-4": {
      "voice": "charon",
      "gender": "m",
      "kind": "verse",
      "text": "ἐν αὐτῷ ζωὴ ἦν, καὶ ἡ ζωὴ ἦν τὸ φῶς τῶν ἀνθρώπων·",
      "ref": "1:4",
      "source": "john"
    },
    "john-1-5": {
      "voice": "charon",
      "gender": "m",
      "kind": "verse",
      "text": "καὶ τὸ φῶς ἐν τῇ σκοτίᾳ φαίνει, καὶ ἡ σκοτία αὐτὸ οὐ κατέλαβεν.",
      "ref": "1:5",
      "source": "john"
    },
